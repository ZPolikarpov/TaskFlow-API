{
    "Jwt": {
        "Secret": "your-secret-key-minimum-32-characters-long",
        "Issuer": "https://taskflow.api",
        "Audience": "https://taskflow.client",
        "ExpiryHours": 1
    },
    "ConnectionStrings": {
        "Default": "Server=your-server,your-port;Database=your-db;User Id=your-user;Password=your-Password;TrustServerCertificate=True"
    },
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*"
}